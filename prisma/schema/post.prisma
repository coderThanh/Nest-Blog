model Post {
    id               String       @id @default(cuid())
    status           RecordStatus @default(DRAFT)
    name             String
    slug             String       @unique @default(dbgenerated())
    search           String?      @default(dbgenerated())
    content          String
    shortDescription String?      @map("short_description")
    thumbnailId      String?      @map("thumbnail_id")
    createdAt        DateTime     @default(now()) @map("created_at")
    updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at")
    createdBy        String?      @map("created_by")

    // 
    createdByUser User?      @relation("postAuth", fields: [createdBy], references: [id], onDelete: SetNull)
    thumbnail     File?      @relation("postThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)
    categories    Category[] @relation("PostToCategory")
    tags          Tag[]      @relation("PostToTag")

    @@index([search(ops: raw("gin_trgm_ops"))], type: Gin)
    @@index([createdAt(sort: Desc)])
    @@index([createdBy])
}
