model Category {
    id          Int     @id @default(autoincrement())
    name        String
    slug        String  @unique @default(dbgenerated())
    search      String? @default(dbgenerated("lower(immute_unaccent(name))"))
    path        String @default("")
    description String?

    thumbnailId String? @map("thumbnail_id")
    thumbnail   File?   @relation("categoryThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)

    parentId Int?       @map("parent_id")
    parent   Category?  @relation("parent", fields: [parentId], references: [id], onDelete: SetNull)
    children Category[] @relation("parent")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

    createdBy     String? @map("created_by")
    createdByUser User?   @relation("categoryAuthor", fields: [createdBy], references: [id], onDelete: SetNull)

    posts Post[] @relation("PostToCategory")

    @@unique([name, parentId])
    @@index([search(ops: raw("gin_trgm_ops"))], type: Gin)
    @@index([path])
}
